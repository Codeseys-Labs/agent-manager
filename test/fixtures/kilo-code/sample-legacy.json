{
  "mcpServers": {
    "server1": {
      "command": "python",
      "args": ["/path/to/server.py"],
      "env": {
        "API_KEY": "test-key"
      },
      "alwaysAllow": ["tool1", "tool2"],
      "disabled": false
    },
    "disabled-legacy": {
      "command": "node",
      "args": ["disabled.js"],
      "disabled": true
    }
  }
}
