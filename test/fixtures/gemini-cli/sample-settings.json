{
  "general": {
    "vimMode": false,
    "defaultApprovalMode": "default"
  },
  "model": {
    "name": "gemini-2.5-pro"
  },
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "tavily": {
      "command": "bunx",
      "args": ["tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "context7": {
      "command": "bunx",
      "args": ["@upstash/context7-mcp@latest"]
    },
    "trusted-server": {
      "command": "my-mcp",
      "trust": true,
      "timeout": 60000
    }
  }
}
