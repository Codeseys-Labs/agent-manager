{
  "numStartups": 42,
  "mcpServers": {
    "fetch": { "command": "uvx", "args": ["mcp-server-fetch"] },
    "tavily": { "command": "bunx", "args": ["tavily-mcp@latest"], "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" } },
    "context7": { "command": "bunx", "args": ["@upstash/context7-mcp@latest"] },
    "exa": { "command": "uvx", "args": ["mcp-proxy", "--endpoint", "https://mcp.exa.ai/sse"], "env": { "EXA_API_KEY": "${EXA_API_KEY}" } },
    "time": { "command": "uvx", "args": ["mcp-server-time"] }
  }
}
