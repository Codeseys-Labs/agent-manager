{
  "name": "agent-manager",
  "version": "0.1.0",
  "description": "chezmoi for AI agent configs — define once in TOML, sync via git, generate native configs for every tool",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "agent-manager": "src/cli.ts",
    "am": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test test/core test/adapters",
    "test:integration": "bun test test/integration",
    "lint": "bunx @biomejs/biome check ./src ./test",
    "lint:fix": "bunx @biomejs/biome check --write ./src ./test",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "@clack/prompts": "^0.9.1",
    "zod": "^3.24.4",
    "@iarna/toml": "^2.2.5",
    "isomorphic-git": "^1.27.2",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
