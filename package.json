{
  "name": "agent-manager",
  "version": "0.5.0-rc6",
  "description": "the control plane for AI agents — catalog, MCP gateway, protocol router (ACP/A2A), marketplace, LLM-wiki, and multi-UI",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "agent-manager": "bin/am.js",
    "am": "bin/am.js",
    "am-acp-shell": "bin/am-acp-shell.js"
  },
  "files": [
    "src/",
    "bin/",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "agent",
    "mcp",
    "config",
    "claude",
    "cursor",
    "copilot",
    "windsurf",
    "gemini",
    "toml",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Codeseys-Labs/agent-manager.git"
  },
  "homepage": "https://github.com/Codeseys-Labs/agent-manager",
  "engines": {
    "node": ">=18",
    "bun": ">=1.1"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:unit": "bun test test/core test/adapters",
    "test:integration": "bun test test/integration",
    "lint": "bunx @biomejs/biome check ./src ./test",
    "lint:fix": "bunx @biomejs/biome check --write ./src ./test",
    "lint:fix:unsafe": "bunx @biomejs/biome check --write --unsafe ./src ./test",
    "typecheck": "bun x tsc --noEmit",
    "dev:web": "wrangler dev",
    "deploy:web": "wrangler deploy",
    "web:kv:create": "wrangler kv namespace create AM_SESSIONS"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@clack/prompts": "^0.9.1",
    "@iarna/toml": "^2.2.5",
    "@silvery/ag-term": "^0.5.0",
    "@silvery/ink": "^0.5.0",
    "citty": "^0.1.6",
    "hono": "^4.12.12",
    "isomorphic-git": "^1.27.2",
    "minisearch": "^7.2.0",
    "react": "^19.2.4",
    "silvery": "^0.10.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@cloudflare/workers-types": "^4.20250401.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5.8.3",
    "wrangler": "^4.14.0"
  },
  "license": "MIT",
  "overrides": {
    "@silvery/commander": "0.8.1"
  }
}
